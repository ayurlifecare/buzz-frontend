# ═══════════════════════════════════════════════════════════
#  Buzz Mart — Customer Web
#  Copy to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════

# Rendering Mode
# "true"  = SSR — Vercel / any Node.js host
# "false" = Static export — Netlify / cPanel / S3
NEXT_PUBLIC_SSR=true

# Backend API URL (no trailing slash)
NEXT_PUBLIC_ADMIN_PANEL_URL=https://api.yourdomain.com

# Your website URL (for SEO / sitemap / OG tags)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
